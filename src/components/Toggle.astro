---
// src/components/Toggle.astro
//
// In MDX files, code fences inside this component's slot are fully
// processed by Astro so syntax highlighting should work correctly.

interface Props {
  label: string;        // accepts plain text or HTML string
  flag?: boolean;       // flag-reveal toggle: adds .toggle-flag for the lime accent (see custom.css)
  class?: string;       // optional extra class (e.g. spoiler-toggle); layered on top of .toggle
}
const { label, flag = false, class: className } = Astro.props;
---

<details class:list={['toggle', { 'toggle-flag': flag }, className]}>
  <summary set:html={label}></summary>
  <div class="toggle-body">
    <slot />
  </div>
</details>