---
import {
  platformLogos, platformIcons, osLogos, osIcons, environmentIcons, platformSlug, difficultyLevel,
  type Platform, type OS, type Environment, type Difficulty,
} from './icons';

interface Props {
  platform: Platform;
  os: OS;
  environment: Environment;
  // OPTIONAL, and the only optional axis. A progressive wargame (OverTheWire Bandit) carries no
  // difficulty rating, and the union has no honest "none" member, so the axis is omitted rather than
  // invented. Omit it and the Difficulty chip does not render at all; supply it and nothing changes.
  difficulty?: Difficulty;
}
const { platform, os, environment, difficulty } = Astro.props;

const platformClass: Record<Platform, string> = {
  HackTheBox: 'pf-htb', VulnHub: 'pf-vh', PicoCTF: 'pf-pico', OverTheWire: 'pf-otw',
};

// The four axes are string-literal unions, but `astro build` does not type-check .astro props and
// this repo has no `astro check` (it would pull in @astrojs/check + typescript). So the unions are
// only enforced in the editor, and a typo like difficulty="Hardd" would ship silently: data-level is
// dropped so no pips fill, the href becomes /platform/undefined, and screen readers announce
// "Difficulty undefined of 4". Fail the build instead of shipping that.
// Platform and OS each span TWO registries (polychrome <img> vs monochrome set:html), so every axis
// is checked against the union of its registries. This replaces the previous per-axis check plus a
// bespoke OS block: without it, platform="HackTheBox" would now throw, because HackTheBox has moved
// out of platformLogos and into platformIcons.
// `difficulty` joins the list only when it is supplied, because it is optional (see Props): an absent
// value is a deliberate omission, while a value that IS present is still checked, so difficulty="Hardd"
// fails the build exactly as before. Never give it a fallback; inventing a rating for content that has
// none is the precise thing the omission exists to prevent.
const axes: ReadonlyArray<readonly [string, string, readonly object[]]> = [
  ['platform', platform, [platformLogos, platformIcons]],
  ['os', os, [osLogos, osIcons]],
  ['environment', environment, [environmentIcons]],
  ...(difficulty === undefined ? [] : [['difficulty', difficulty, [difficultyLevel]] as const]),
];
for (const [name, value, registries] of axes) {
  if (!registries.some((r) => Object.prototype.hasOwnProperty.call(r, value))) {
    const known = registries.flatMap((r) => Object.keys(r));
    throw new Error(`WriteupMeta: unknown ${name} "${value}". Expected one of: ${known.join(', ')}.`);
  }
}

const level = difficulty === undefined ? undefined : difficultyLevel[difficulty];
const osSlug = os.toLowerCase();
const envSlug = environment.toLowerCase().replace(/\s+/g, '-');
// Per-value classes so CSS can color each chip (the slugs double as the class suffixes):
const osClass = `wm-os-${osSlug}`;    // wm-os-linux | wm-os-windows
const envClass = `wm-env-${envSlug}`; // wm-env-standalone | wm-env-active-directory
---
<!--
  Metadata chips are intentionally NON-INTERACTIVE until the /platform, /os and /environment filter
  routes ship (revisit after the mass writeup import). Those routes do not exist yet, so a clickable
  chip would point at a dead route; the chips render as static <span> below instead of <a>. The
  clickable <a> version is preserved as a comment right above the spans so it restores verbatim once
  the routes exist. See DECISIONS 2026-07-11 (metadata system entry).
-->
<!--
  `not-content` opts the chips out of Starlight's prose styling. Every .sl-markdown-content rule is
  guarded with :not(:where(.not-content *)), so this is the framework's own escape hatch: without it
  the prose-link rules (which reach (0,3,1) under :root[data-theme='light']) outrank the chip's own
  color and border, painting the labels teal with a tinted bottom edge in light mode. The guard skips
  descendants only, so .writeup-meta itself keeps its normal flow margins.
-->
<div class="writeup-meta not-content">
  <div class="wm-nav">
    {/* Metadata chips are intentionally non-interactive until the /platform, /os and /environment
        filter routes ship, to be revisited after the mass writeup import. The clickable <a> version
        is kept here (commented) so it restores verbatim: swap the three static <span class="wm-chip">
        below back to these anchors once the routes exist, and drop the data-astro-prefetch="false"
        attrs then (they exist only to stop Starlight prefetching dead routes).
    <a class={`wm-chip ${platformClass[platform]}`} href={`/platform/${platformSlug[platform]}`} data-astro-prefetch="false">
      {platform === 'HackTheBox'
        ? <span class="wm-ico" set:html={platformIcons.HackTheBox} />
        : <img class="wm-ico wm-ico-logo" src={platformLogos[platform]} alt="" width="15" height="15" loading="lazy" decoding="async" />}{platform}
    </a>
    <a class={`wm-chip ${osClass}`} href={`/os/${osSlug}`} data-astro-prefetch="false">
      {os === 'Linux'
        ? <img class="wm-ico wm-ico-logo" src={osLogos.Linux} alt="" width="15" height="15" loading="lazy" decoding="async" />
        : <span class="wm-ico" set:html={osIcons.Windows} />}{os}
    </a>
    <a class={`wm-chip ${envClass}`} href={`/environment/${envSlug}`} data-astro-prefetch="false">
      <span class="wm-ico wm-ico-env" set:html={environmentIcons[environment]} />{environment}
    </a>
    */}
    <span class={`wm-chip ${platformClass[platform]}`}>
      {platform === 'HackTheBox'
        ? <span class="wm-ico" set:html={platformIcons.HackTheBox} />
        : <img class="wm-ico wm-ico-logo" src={platformLogos[platform]} alt="" width="15" height="15" loading="lazy" decoding="async" />}{platform}
    </span>
    <span class={`wm-chip ${osClass}`}>
      {os === 'Linux'
        ? <img class="wm-ico wm-ico-logo" src={osLogos.Linux} alt="" width="15" height="15" loading="lazy" decoding="async" />
        : <span class="wm-ico" set:html={osIcons.Windows} />}{os}
    </span>
    <span class={`wm-chip ${envClass}`}>
      <span class="wm-ico wm-ico-env" set:html={environmentIcons[environment]} />{environment}
    </span>
  </div>
  {difficulty !== undefined && (
    <span class="wm-diff">
      <span class="wm-diff-chip">
        {difficulty}
        <span class="wm-pips" data-level={level} aria-hidden="true">
          <i></i><i></i><i></i><i></i>
        </span>
        <span class="sr-only">{`Difficulty ${level} of 4`}</span>
      </span>
    </span>
  )}
</div>
