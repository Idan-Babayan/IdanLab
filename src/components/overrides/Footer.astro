---
// src/components/overrides/Footer.astro
//
// Additive override of Starlight's content Footer (approved pattern, the second instance after
// PageSidebar). Footer is the only default component that renders the Prev/Next <Pagination /> after
// the Markdown content, so it is the correct seam for the design's Principle coda plus its silence.
//
// Behavior:
//   - Non-writeup pages, and writeups with no `principle`: render Starlight's <Default /> Footer
//     unchanged, so pagination (and any meta) stay exactly as before. Pagination is never removed
//     site-wide.
//   - Writeups whose frontmatter declares a non-empty `principle`: render ONLY the shipped <Principle>
//     coda, so it is the last thing on the page and no pagination or footer block renders beneath it.
//     The silence is coupled to the coda: without a principle the default footer renders normally.
//
// This is additive composition, not a fork: the default Footer markup is never reimplemented. For the
// coda case the design's own component replaces the (pagination-only) footer, which is the sanctioned
// way to omit pagination for these pages without touching the default markup.
//
// Writeup detection uses entry.filePath (always present for Starlight's file-based loader): a source
// file under a platform directory that is not an index page. That includes hackthebox/<tier>/<slug>
// and overthewire/bandit/<level>, and excludes the platform landings, the Bandit hub (index.mdx), 404,
// and secret. The marketing home and about pages are not Starlight docs, so this override never runs
// there.
//
// The coda is wrapped in a .sl-markdown-content element on purpose: the design's Principle styles live
// in custom.css scoped as `.sl-markdown-content .principle` (Design owns that CSS, untouched here), and
// Footer renders outside the content wrapper. The wrapper reproduces the exact ancestor context the
// coda was authored and verified in, with no container side effects (no bare `.sl-markdown-content {}`
// rule exists). If Design later un-scopes those rules to bare `.principle`, this wrapper can be dropped.
import Default from '@astrojs/starlight/components/Footer.astro';
import Principle from '@components/Principle.astro';

const { entry } = Astro.locals.starlightRoute;
const filePath = entry.filePath;

const isWriteup =
  /\/docs\/(hackthebox|vulnhub|picoctf|overthewire)\//.test(filePath) &&
  !/\/index\.(md|mdx)$/.test(filePath);

const principle = entry.data.principle;
const codaText = isWriteup && typeof principle === 'string' ? principle.trim() : '';
const showCoda = codaText.length > 0;
---
{
  showCoda ? (
    <div class="sl-markdown-content">
      <Principle text={codaText} />
    </div>
  ) : (
    <Default />
  )
}
