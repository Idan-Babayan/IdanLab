---
// src/components/PasswordReveal.astro
//
// Wargame password reveal. Deliberately NOT FlagCapture: a wargame password (OverTheWire Bandit, etc.)
// is a WAYPOINT the reader pastes into SSH, not a trophy. So this uses the AMBER spoiler identity, no
// gold/loot styling, and NO signature decode (reserved for FlagCapture flags). Calm enough to appear on
// all 34 Bandit pages.
//
// Layout: PASSWORD label, the value blurred (spoiler-protected, plain text with no clickable framing),
// then ONE control on the right. It starts as eye + "Reveal"; on click the value unblurs and the SAME
// control swaps in place to copy + "Copy" (no layout shift, focus stays put). It is the ONLY interactive
// element in the row: the container and the value carry no click handler and no hover/press affordance.
//
// Accessibility: the value is always in the DOM (blur is purely visual), so screen readers get it. The
// control is a real <button>. Reveal/copy are announced via a VISUALLY HIDDEN aria-live region.
// prefers-reduced-motion skips the blur transition.

interface Props {
  /** The password value. Present in the DOM for screen readers and copy; visually blurred until reveal. */
  password: string;
}

const { password } = Astro.props;
---

<div class="pwreveal" data-pwreveal data-password={password}>
  <span class="pw-label">Password</span>
  <code class="pw-value">{password}</code>

  <button type="button" class="pw-action" aria-label="Reveal password">
    <svg class="pw-action-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path class="pw-action-path" d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" stroke-linecap="round" stroke-linejoin="round" />
      <circle class="pw-action-eye" cx="12" cy="12" r="3" />
    </svg>
    <span class="pw-action-text">Reveal</span>
  </button>

  <span class="pw-live sr-only" aria-live="polite"></span>
</div>

<script>
  const COPY_PATH =
    'M16 1H4a2 2 0 0 0-2 2v14h2V3h12zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H8V7h11z';

  function legacyCopy(text: string): void {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    try {
      document.execCommand('copy');
    } catch (_e) {
      /* no-op: clipboard simply unavailable */
    }
    ta.remove();
  }

  function copyText(text: string): void {
    const write = navigator.clipboard?.writeText(text);
    if (write && typeof write.catch === 'function') {
      write.catch(() => legacyCopy(text));
    } else {
      legacyCopy(text);
    }
  }

  function bind(root: HTMLElement): void {
    if (root.dataset.pwReady === 'true') return;
    root.dataset.pwReady = 'true';

    const btn = root.querySelector('.pw-action') as HTMLButtonElement | null;
    const ico = root.querySelector('.pw-action-ico') as SVGElement | null;
    const path = root.querySelector('.pw-action-path') as SVGPathElement | null;
    const eye = root.querySelector('.pw-action-eye') as SVGCircleElement | null;
    const text = root.querySelector('.pw-action-text') as HTMLElement | null;
    const live = root.querySelector('.pw-live') as HTMLElement | null;
    const password = root.dataset.password ?? '';
    if (!btn) return;

    let revertId = 0;

    btn.addEventListener('click', () => {
      // First click: reveal. Value unblurs; the control becomes Copy in place.
      if (root.dataset.revealed !== 'true') {
        root.dataset.revealed = 'true';
        root.classList.add('is-revealed');
        if (eye) eye.remove(); // the copy glyph is a single filled path; drop the eye circle
        if (path) {
          path.setAttribute('d', COPY_PATH);
          path.removeAttribute('stroke-linecap');
          path.removeAttribute('stroke-linejoin');
        }
        if (ico) {
          ico.setAttribute('fill', 'currentColor');
          ico.removeAttribute('stroke');
        }
        if (text) text.textContent = 'Copy';
        btn.setAttribute('aria-label', 'Copy to clipboard');
        if (live) live.textContent = 'Password revealed';
        return;
      }

      // Subsequent clicks: copy, with a brief confirmation that reverts.
      copyText(password);
      if (text) text.textContent = 'Copied';
      if (live) live.textContent = 'Password copied';
      window.clearTimeout(revertId);
      revertId = window.setTimeout(() => {
        if (text) text.textContent = 'Copy';
      }, 1400);
    });
  }

  function init(): void {
    (document.querySelectorAll('[data-pwreveal]') as NodeListOf<HTMLElement>).forEach(bind);
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
