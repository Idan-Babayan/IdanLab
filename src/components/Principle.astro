---
interface Props {
  text: string;
}
const { text } = Astro.props;
---
<aside class="principle" aria-label="Principle">
  <span class="principle-dinkus" aria-hidden="true">&middot; &middot; &middot;</span>
  <span class="principle-label">Principle</span>
  <p class="principle-text">{text}</p>
</aside>
