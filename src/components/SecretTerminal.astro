---
/**
 * SecretTerminal: a from-scratch, zero-dependency interactive terminal (vanilla TS).
 *
 * Embedded in src/content/docs/secret.mdx (Starlight splash template) so it inherits the
 * site chrome and follows the theme toggle. No libraries, no npm packages.
 *
 * Output rendering: the output container is white-space: pre-wrap, so "\n" in authored
 * command output renders as real line breaks (this is why help is multi-line). Color comes
 * from authored <span> role classes (cyan / lime / coral / dim). Authored output is trusted
 * and assigned via innerHTML; anything the visitor typed (the echoed line, a cat filename)
 * is HTML-escaped first. Palette is defined as CSS custom properties and re-mapped under
 * html[data-theme="light"], so the terminal follows Starlight's theme automatically.
 *
 * The writeup list for `random` is built HERE at build time (never hardcoded) and serialized
 * into a data attribute the client parses.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

type DocEntry = CollectionEntry<'docs'>;

// Real writeups live under {platform}/{difficulty}/{slug}. Filtering by a known platform
// prefix excludes the platform index pages, /secret, /404, and /guides, and stays correct
// as writeups are added.
const KNOWN_PLATFORMS = ['hackthebox', 'vulnhub', 'picoctf', 'overthewire'] as const;

const all: DocEntry[] = await getCollection('docs');
const writeupUrls: string[] = all
	.filter((e) => KNOWN_PLATFORMS.some((p) => e.id.startsWith(`${p}/`)))
	// Starlight lowercases doc URLs even though entry ids preserve folder casing.
	.map((e) => `/${e.id.toLowerCase()}/`)
	.sort();
---

<div class="term-wrap not-content">
	<div class="term" id="term" data-writeups={JSON.stringify(writeupUrls)}>
		<div class="term-bar">
			<span class="term-dot term-dot-r" aria-hidden="true"></span>
			<span class="term-dot term-dot-y" aria-hidden="true"></span>
			<span class="term-dot term-dot-g" aria-hidden="true"></span>
			<span class="term-bar-title">visitor@idanlab: ~/secret</span>
			<span class="term-live" aria-hidden="true"><span class="term-live-dot"></span>online</span>
		</div>
		<div class="term-scroll" id="term-scroll">
			<div class="term-output" id="term-output" role="log" aria-live="polite" aria-label="terminal output"></div>
			<div class="term-line">
				<span class="term-pfx">visitor@idanlab:~$</span>
				<input
					class="term-input"
					id="term-input"
					type="text"
					autocomplete="off"
					autocapitalize="off"
					autocorrect="off"
					spellcheck="false"
					aria-label="terminal command input"
				/>
			</div>
		</div>
	</div>
	<p class="term-hint">New here? Type <code>help</code> and press Enter. (Yes, recruiter friend, you too.)</p>
</div>

<style>
	.term-wrap {
		max-width: 52rem;
		margin: 1.5rem auto 0;
	}

	.term {
		/* Dark palette (default). Re-mapped under html[data-theme="light"] below. */
		--t-surface: #0a0e10;
		--t-bar: #0d1214;
		--t-border: #1d2a2e;
		--t-text: #d4dde2;
		--t-dim: #6b7a80;
		--t-cyan: #41efff;
		--t-lime: #b6ff3c;
		--t-coral: #ff8787;

		background: var(--t-surface);
		color: var(--t-text);
		border: 1px solid var(--t-border);
		border-radius: 12px;
		overflow: hidden;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		box-shadow: 0 18px 50px -28px rgba(0, 0, 0, 0.8);
	}
	html[data-theme='light'] .term {
		--t-surface: #eef1f2;
		--t-bar: #e3e8ea;
		--t-border: #d3dadd;
		--t-text: #1b2326;
		--t-dim: #5b696f;
		--t-cyan: #096577;
		--t-lime: #426f10;
		--t-coral: #c92a2a;
		box-shadow: 0 14px 40px -24px rgba(60, 50, 30, 0.5);
	}

	.term-bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 0.85rem;
		background: var(--t-bar);
		border-bottom: 1px solid var(--t-border);
	}
	.term-dot {
		width: 0.72rem;
		height: 0.72rem;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.term-dot-r {
		background: #ff5f56;
	}
	.term-dot-y {
		background: #ffbd2e;
	}
	.term-dot-g {
		background: #27c93f;
	}
	.term-bar-title {
		margin-left: 0.4rem;
		font-size: 0.72rem;
		letter-spacing: 0.05em;
		color: var(--t-dim);
	}
	.term-live {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--t-dim);
	}
	.term-live-dot {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 50%;
		background: var(--t-lime);
		box-shadow: 0 0 6px var(--t-lime);
		animation: term-pulse 1.8s ease-in-out infinite;
	}

	.term-scroll {
		padding: 1rem 1.1rem 1.15rem;
		min-height: 19rem;
		max-height: 62vh;
		overflow-y: auto;
		font-size: 0.86rem;
		line-height: 1.55;
		cursor: text;
	}

	/* pre-wrap is the fix for multi-line output: "\n" becomes a real line break. */
	.term-output {
		white-space: pre-wrap;
		overflow-wrap: anywhere;
	}

	/* Output blocks and colored spans are injected at runtime via innerHTML, so they do
	   NOT carry Astro's scope hash. Gate these rules with :global() under the scoped
	   .term / .term-output ancestor: they apply to the dynamic nodes, but only inside
	   this terminal (the scoped ancestor prevents any leakage). The --t-* role colors are
	   inherited from .term, which flips them under the light theme. */
	.term-output :global(.term-echo) {
		margin-top: 0.55rem;
	}
	.term :global(.c-cyan) {
		color: var(--t-cyan);
	}
	.term :global(.c-lime) {
		color: var(--t-lime);
	}
	.term :global(.c-coral) {
		color: var(--t-coral);
	}
	.term :global(.c-dim) {
		color: var(--t-dim);
	}

	/* Flag payoff: glow in dark, plain bold in light (a glow smudges on a pale surface). */
	.term :global(.flag-line) {
		color: var(--t-lime);
		font-weight: 700;
		text-shadow: 0 0 12px color-mix(in oklab, var(--t-lime) 55%, transparent);
	}
	html[data-theme='light'] .term :global(.flag-line) {
		text-shadow: none;
	}

	.term-line {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-top: 0.55rem;
	}
	.term-pfx {
		color: var(--t-cyan);
		flex-shrink: 0;
	}
	.term-input {
		flex: 1 1 auto;
		min-width: 0;
		background: transparent;
		border: none;
		outline: none;
		color: var(--t-text);
		font-family: inherit;
		font-size: 0.86rem;
		line-height: 1.55;
		padding: 0;
		caret-color: var(--t-lime);
	}

	.term-hint {
		text-align: center;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.8rem;
		color: color-mix(in oklab, var(--sl-color-text) 60%, transparent);
		margin: 1rem auto 0;
	}
	.term-hint code {
		background: color-mix(in oklab, var(--sl-color-accent) 16%, transparent);
		color: var(--sl-color-accent);
		padding: 0.05rem 0.4rem;
		border-radius: 5px;
		font-family: inherit;
	}

	@keyframes term-pulse {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.3;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.term-live-dot {
			animation: none;
		}
	}
</style>

<script>
	const term = document.getElementById('term') as HTMLElement | null;
	const scroll = document.getElementById('term-scroll') as HTMLElement | null;
	const output = document.getElementById('term-output') as HTMLElement | null;
	const input = document.getElementById('term-input') as HTMLInputElement | null;

	if (term && scroll && output && input) {
		const PROMPT = 'visitor@idanlab:~$';

		// ===== Build-time writeup list (trusted, our own content) =====
		let writeups: string[] = [];
		try {
			const parsed: unknown = JSON.parse(term.dataset.writeups ?? '[]');
			if (Array.isArray(parsed)) writeups = parsed.filter((u): u is string => typeof u === 'string');
		} catch {
			writeups = [];
		}

		// ===== Helpers =====
		const escapeHtml = (s: string): string =>
			s.replace(
				/[&<>"']/g,
				(c) =>
					({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] ?? c
			);

		const pick = <T,>(arr: readonly T[]): T => arr[Math.floor(Math.random() * arr.length)] as T;

		const longestCommonPrefix = (strs: string[]): string => {
			if (strs.length === 0) return '';
			let prefix = strs[0] ?? '';
			for (const s of strs) {
				while (!s.startsWith(prefix)) {
					prefix = prefix.slice(0, -1);
					if (prefix === '') return '';
				}
			}
			return prefix;
		};

		const scrollDown = (): void => {
			scroll.scrollTop = scroll.scrollHeight;
		};

		// Trusted print: html is authored output (may contain span markup).
		const printOut = (html: string): void => {
			const div = document.createElement('div');
			div.className = 'term-block';
			div.innerHTML = html;
			output.appendChild(div);
		};
		// Echo: prompt is authored, the typed command is escaped.
		const printEcho = (raw: string): void => {
			const div = document.createElement('div');
			div.className = 'term-block term-echo';
			div.innerHTML = `<span class="c-cyan">${PROMPT}</span> ${escapeHtml(raw)}`;
			output.appendChild(div);
		};
		const clearScreen = (): void => {
			output.replaceChildren();
		};

		// ===== Content pools =====
		const WHOAMI: readonly string[] = [
			'Access granted.\nWait... who approved this?',
			'404: Identity not found.',
			'You are visitor number yes. Welcome aboard.',
			'A curious human. The most dangerous kind.',
			'Someone who reads the secret page for fun. We will get along.',
		];

		const SUDO: readonly string[] = [
			'Permission denied.\nNice try.',
			'Permission denied.\nYou are not in the sudoers file. As it should be.',
			'Permission denied.\nThis incident has been reported. (it has not.)',
		];

		const FILES: Record<string, string> = {
			'about.txt':
				'idan. cybersecurity person. breaks things on purpose, then writes\ndown why they broke. currently turning curiosity into a career.',
			'notes.md': 'TODO: stop building easter eggs.\nTODO: ignore the previous todo.',
			'writeups/':
				'<span class="c-coral">cat: writeups/: Is a directory</span>\n<span class="c-dim">(try \'random\' to open one)</span>',
			'.secret':
				'<span class="c-lime">nice, you found the hidden file.</span>\nthe payoff is one command away. type <span class="c-lime">flag</span> and see what happens.',
		};
		const fileNames: string[] = Object.keys(FILES);

		const COMMAND_HELP: ReadonlyArray<readonly [string, string]> = [
			['help', 'show this list'],
			['whoami', 'a brief identity crisis'],
			['ls', 'look around'],
			['cat <file>', 'read a file'],
			['sudo', 'please do not'],
			['random', 'warp to a random writeup (also: surprise, roll)'],
			['flag', 'for those who made it this far'],
			['clear', 'wipe the screen'],
		];

		// ===== Command handlers (registry types as Record<string, (arg) => string>) =====
		const helpText = (): string => {
			const body = COMMAND_HELP.map(
				([name, desc]) => `<span class="c-lime">${escapeHtml(name).padEnd(22)}</span><span class="c-dim">${desc}</span>`
			).join('\n');
			return `${body}\n\n<span class="c-dim">tip: Tab autocompletes. Up/Down walk your history.</span>`;
		};

		const lsOutput = (): string => {
			const cells = fileNames.map((n) =>
				n.startsWith('.') ? `<span class="c-cyan">${n}</span>` : `<span class="c-lime">${n}</span>`
			);
			return `${cells.join('   ')}\n<span class="c-dim">(1 hidden file)</span>`;
		};

		const catOutput = (arg: string): string => {
			if (arg === '') return '<span class="c-dim">usage: cat &lt;file&gt;. run \'ls\' to see what is here.</span>';
			const content = FILES[arg];
			if (content === undefined)
				return `<span class="c-coral">cat: ${escapeHtml(arg)}: No such file or directory</span>`;
			return content;
		};

		const goRandom = (): string => {
			if (writeups.length === 0)
				return '<span class="c-dim">the vault is empty. no writeups logged yet, check back soon.</span>';
			const url = pick(writeups);
			window.setTimeout(() => window.location.assign(url), 350);
			return '<span class="c-cyan">rolling the dice...</span>';
		};

		const flagOutput = (): string =>
			[
				'<span class="flag-line">flag{curiosity_is_my_exploit}</span>',
				'',
				'you poked at a portfolio until it poked back. respect.',
				'',
				'<span class="c-cyan">recruiter? this is the part i do for fun.</span>',
				'<span class="c-cyan">imagine me on the clock. say hi: contact@idanlab.dev</span>',
			].join('\n');

		const registry: Record<string, (arg: string) => string> = {
			help: () => helpText(),
			whoami: () => pick(WHOAMI),
			sudo: () => `<span class="c-coral">${pick(SUDO)}</span>`,
			ls: () => lsOutput(),
			cat: (arg) => catOutput(arg),
			random: () => goRandom(),
			surprise: () => goRandom(),
			roll: () => goRandom(),
			clear: () => {
				clearScreen();
				return '';
			},
			flag: () => flagOutput(),
		};
		const commandNames: string[] = Object.keys(registry);

		// ===== Run a command line =====
		const run = (raw: string): void => {
			printEcho(raw);
			const trimmed = raw.trim();
			if (trimmed !== '') {
				const space = trimmed.indexOf(' ');
				const name = (space === -1 ? trimmed : trimmed.slice(0, space)).toLowerCase();
				const arg = space === -1 ? '' : trimmed.slice(space + 1).trim();
				const handler = registry[name];
				if (handler) {
					const out = handler(arg);
					if (out !== '') printOut(out);
				} else {
					printOut(
						`<span class="c-coral">command not found: ${escapeHtml(name)}</span>\n<span class="c-dim">type 'help' to see what works.</span>`
					);
				}
			}
			scrollDown();
		};

		// ===== History =====
		const history: string[] = [];
		let cursor = 0;

		// ===== Tab completion =====
		const completeFrom = (token: string, pool: string[], prefix: string): void => {
			const matches = pool.filter((c) => c.startsWith(token));
			if (matches.length === 0) return;
			if (matches.length === 1) {
				input.value = `${prefix}${matches[0]}${prefix === '' ? ' ' : ''}`;
				return;
			}
			const lcp = longestCommonPrefix(matches);
			if (lcp.length > token.length) input.value = `${prefix}${lcp}`;
			else {
				printOut(`<span class="c-dim">${matches.join('   ')}</span>`);
				scrollDown();
			}
		};
		const handleTab = (): void => {
			const tokens = input.value.split(/\s+/);
			if (tokens.length <= 1) {
				const token = tokens[0] ?? '';
				if (token === '') return;
				completeFrom(token, commandNames, '');
			} else if ((tokens[0] ?? '').toLowerCase() === 'cat') {
				completeFrom(tokens[1] ?? '', fileNames, 'cat ');
			}
		};

		const caretToEnd = (): void => {
			window.requestAnimationFrame(() => input.setSelectionRange(input.value.length, input.value.length));
		};

		input.addEventListener('keydown', (e: KeyboardEvent) => {
			if (e.key === 'Enter') {
				const value = input.value;
				input.value = '';
				const trimmed = value.trim();
				if (trimmed !== '' && history[history.length - 1] !== trimmed) history.push(trimmed);
				cursor = history.length;
				run(value);
			} else if (e.key === 'ArrowUp') {
				if (history.length === 0) return;
				e.preventDefault();
				cursor = Math.max(0, cursor - 1);
				input.value = history[cursor] ?? '';
				caretToEnd();
			} else if (e.key === 'ArrowDown') {
				if (history.length === 0) return;
				e.preventDefault();
				cursor = Math.min(history.length, cursor + 1);
				input.value = cursor === history.length ? '' : history[cursor] ?? '';
				caretToEnd();
			} else if (e.key === 'Tab' && !e.shiftKey) {
				// Forward Tab autocompletes; Shift+Tab is left alone so focus can still leave
				// the input (no focus trap).
				e.preventDefault();
				handleTab();
			}
		});

		// Clicking the console focuses the input (unless the visitor is selecting text).
		term.addEventListener('click', () => {
			if ((window.getSelection()?.toString() ?? '') !== '') return;
			input.focus({ preventScroll: true });
		});

		// Boot line (printed instantly, no animation to gate for reduced-motion).
		printOut(
			'<span class="c-dim">idanlab secure shell. unauthorized curiosity is encouraged.</span>\n<span class="c-dim">type </span><span class="c-lime">help</span><span class="c-dim"> to get started.</span>'
		);
		input.focus({ preventScroll: true });

		// Styled console greeting (a small wink for anyone who opens devtools here).
		console.log(
			'%c idanlab ',
			'background:#b6ff3c;color:#07090a;font-weight:700;border-radius:3px;padding:2px 4px;',
			"you're in the console. of course you are."
		);
		console.log('%cthe terminal above takes commands. type things into it.', 'color:#41efff;');
	}
</script>
